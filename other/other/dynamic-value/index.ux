      //   },
      //   fail: function(data, code) {
      //     console.log(`handling fail, code = ${code}`)
      //     this.showHint = true;
      //   }
      // })
    },

    getList() {
      return new Promise((resolve) => {
        let list = new Array(5).fill(0).map((item, i) => {
          return {id: i, name: 'Item-' + Math.floor(Math.random() * 1000)};
        });

        setTimeout(() => {
          resolve(list);
        }, 1000 + Math.random() * 1000);
      });
    },

    changeB() {
      // let {list} = this;

      // list[1].name = "B" + Math.floor(Math.random() * 1000);

      // this.list = [...list];
      // this.list = list;

      this.list[1].name = "B" + Math.floor(Math.random() * 1000);

      console.log(this.list);
    }
  }
</script>

