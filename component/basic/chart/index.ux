          gradient:true
        },
        {
          strokeColor: '#cce5ff',
          data: [535, 776, 615, 444, 694, 785, 677, 609, 562, 410],
          gradient:true
        },
        {
          strokeColor: '#ff88bb',
          data: [673, 500, 574, 483, 702, 583, 437, 506, 693, 657],
          gradient:true
        }
      ],
      barOps: {
