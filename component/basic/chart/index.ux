        yAxis: {
          min: 0,
          max: 1000,
          display: true,
          color:'blue'
        },
        // 'series':{
        //   'lineStyle':{
        //     'width':"10px"
        //   }
        // },
        series:{
          lineStyle:{
            width:5
          }
        },
      },
      dataList:[1,2,3],
      if_chart:true,
      show_chart:false,
    },
    onReady() {

    },
