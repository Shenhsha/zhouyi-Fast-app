        {
          name: '衣服',
          price: '100',
        }, {
          name: '裤子',
          price: '200',
        },
        {
          name: '上衣',
          price: '150',
        }
      ],
    },
    onReady() {

    },

    back() {
      router.back();
    }
  }
</script>

