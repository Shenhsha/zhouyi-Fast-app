  }

  .yin-line {
    width: 200px;
    height: 100%;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
  }

  .yin-line-left {
    width: 80px;
    height: 100%;
    background-color: #ffffff;
    border-radius: 5px;
  }

  .yin-line-right {
    width: 80px;
    height: 100%;
    background-color: #ffffff;
