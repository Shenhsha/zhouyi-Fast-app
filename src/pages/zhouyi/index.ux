  }

  .yin-line-space {
    width: 40px;
  }

  .line {
    width: 80px;
    height: 100%;
    background-color: #ffffff;
    border-radius: 5px;
  }

  .old-line {
    background-color: #fde68a !important;
  }

  /* 解卦页展示区 */
  .hexagram-display {
    flex-direction: column-reverse;
    align-items: center;
    justify-content: center;
    width: 100%;
    margin: 28px 0;
  }

  .hexagram-display-small {
    flex-direction: column-reverse;
    align-items: center;
    justify-content: center;
    width: 100%;
    margin: 18px 0 24px;
  }

  .yao-row-small {
    flex-direction: row;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 36px;
    margin-bottom: 11px;
  }

  .yang-line-small {
    width: 200px;
    height: 100%;
    background-color: #ffffff;
    border-radius: 5px;
  }

  .yin-line-small {
    width: 200px;
    height: 100%;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
  }

  .yin-line-left-small,
  .yin-line-right-small {
    width: 80px;
    height: 100%;
    background-color: #ffffff;
    border-radius: 5px;
  }

  .yin-line-space-small {
    width: 40px;
  }

  .change-section {
    flex-direction: column;
    align-items: center;
    width: 100%;
    margin-top: 28px;
  }

  .result-title {
    font-size: 58px;
    font-weight: bold;
    color: #fbbf24;
  }

  .result-subtitle {
    font-size: 30px;
    color: #9ca3af;
    margin-bottom: 18px;
  }

  /* 解卦文本卡片 */
  .card-label {
    font-size: 32px;
    font-weight: bold;
    color: #fbbf24;
  }

  .card-colon {
    font-size: 32px;
    font-weight: bold;
    color: #fbbf24;
    margin-right: 10px;
  }

  .card-content {
    font-size: 24px;
    color: #d1d5db;
  }

  .yao-text {
    font-size: 24px;
    color: #e5e7eb;
    margin-top: 10px;
    line-height: 36px;
  }
</style>

<script>
  import vibrator from '@system.vibrator'
  import HEXAGRAM_DATA from '../../common/hexagram-data.js'

  const LINE_STATES = [7, 8, 9, 6]
  const FALLBACK_HEXAGRAM = { name: '未知卦', ci: '数据缺失', yaoCi: [] }

  export default {
    private: {
      // 页面流转状态：home -> ritual/rules/action -> result。
      currentPage: 'home',
      currentMode: '',
      actionTitle: '起卦',

      // 起卦过程状态。爻值编码：6=老阴，7=少阳，8=少阴，9=老阳。
      shakeCount: 0,
      shakeText: '抛掷铜钱 (0/6)',
      coin1: '字',
      coin2: '字',
      coin3: '字',
      shakeResult: '准备抛掷',
      isShaking: false,
      currentLines: [],
      previewLines: [],
      resultLines: [],
      changedLines: [],
      resultGua: { name: '', ci: '', yaoCi: [] },
      changedGua: { name: '', ci: '', yaoCi: [] },
      showChange: false,
      showOriginalCi: true,
      showChangedCi: false,
      interpretationRule: '',
      interpretationTexts: []
    },

    // 进入起卦前先展示三不占原则，保留当前选择的起卦模式。
    goToRitual(mode) {
      this.currentMode = mode
      this.currentPage = 'ritual'
    },

    goHome() {
      this.currentPage = 'home'
    },

    goRitual() {
      this.currentPage = 'ritual'
    },

    showRules() {
      this.currentPage = 'rules'
    },

    // 根据起卦模式初始化对应的操作页面。
    proceedToAction() {
      if (this.currentMode === 'shake') {
        this.actionTitle = '手动摇卦'
        this.resetShake()
      } else if (this.currentMode === 'manual') {
        this.actionTitle = '手工指定'
        this.resetManual()
      }
      this.currentPage = 'action'
    },

    // 清空六次抛掷进度，等待用户从初爻开始逐次起卦。
    resetShake() {
      this.shakeCount = 0
      this.shakeText = '抛掷铜钱 (0/6)'
      this.currentLines = []
      this.previewLines = []
      this.coin1 = '字'
      this.coin2 = '字'
      this.coin3 = '字'
      this.shakeResult = '准备抛掷'
    },

    // 手工指定默认从六个少阳开始，点击爻位后依次切换四种爻态。
    resetManual() {
      this.currentLines = [7, 7, 7, 7, 7, 7]
      this.updatePreviewLines()
    },

    toggleLine(index) {
      let currentIdx = LINE_STATES.indexOf(this.currentLines[index])
      let nextIdx = (currentIdx + 1) % LINE_STATES.length
      this.currentLines[index] = LINE_STATES[nextIdx]
      this.updatePreviewLines()
    },

    isYangLine(value) {
      return value === 7 || value === 9
    },

    isChangingLine(value) {
      return value === 6 || value === 9
    },

    toLineView(value, index) {
      return {
        index: index,
        value: value,
        isYang: this.isYangLine(value),
        isOld: this.isChangingLine(value)
      }
    },

    buildLineViews(values) {
      let lines = []
      for (let i = 0; i < values.length; i++) {
        lines.push(this.toLineView(values[i], i))
      }
      return lines
    },

    buildChangedLineViews(values) {
      let changedValues = []
      for (let i = 0; i < values.length; i++) {
        changedValues.push(this.getChangedLineValue(values[i]))
      }
      return this.buildLineViews(changedValues)
    },

    getChangedLineValue(value) {
      if (value === 6) return 9
      if (value === 9) return 6
      return value
    },

    getHexagramData(binaryKey) {
      return HEXAGRAM_DATA[binaryKey] || FALLBACK_HEXAGRAM
    },

    vibrate(mode) {
      try {
        vibrator.vibrate({ mode: mode })
      } catch (e) {}
    },

    // 将内部爻值转换为模板渲染需要的阴阳、动爻标记。
    updatePreviewLines() {
      this.previewLines = this.buildLineViews(this.currentLines)
    },

    // 防止连续点击造成重复抛掷，短暂延迟用于表现“抛掷中”的状态。
    triggerShake() {
      if (this.isShaking || this.shakeCount >= 6) return

      this.isShaking = true
      this.shakeResult = '抛掷中...'

      setTimeout(() => {
        this.performToss()
        this.isShaking = false
      }, 500)
    },

    shakeBtnClick() {
      if (this.shakeCount >= 6) {
        this.showResult()
      } else {
        this.triggerShake()
      }
    },

    finishShake() {
      this.showResult()
    },

    // 三枚铜钱按背面数量生成一爻，并即时更新卦象预览。
    performToss() {
      const results = [Math.random() < 0.5, Math.random() < 0.5, Math.random() < 0.5]
      const backCount = results.filter(r => r).length

      this.coin1 = results[0] ? '背' : '字'
      this.coin2 = results[1] ? '背' : '字'
      this.coin3 = results[2] ? '背' : '字'

      let yaoValue
      if (backCount === 1) { yaoValue = 7; this.shakeResult = '少阳' }
      else if (backCount === 2) { yaoValue = 8; this.shakeResult = '少阴' }
      else if (backCount === 3) { yaoValue = 9; this.shakeResult = '老阳' }
      else { yaoValue = 6; this.shakeResult = '老阴' }

      this.currentLines.push(yaoValue)
      this.previewLines.push(this.toLineView(yaoValue, this.currentLines.length - 1))

      this.shakeCount++
      this.shakeText = '抛掷铜钱 (' + this.shakeCount + '/6)'

      this.vibrate('short')

      if (this.shakeCount >= 6) {
        this.shakeText = '起卦完成'
      }
    },

    // 自动/时间起卦直接生成六爻，再统一进入结果计算。
    startDivination(mode) {
      if (mode === 'auto') {
        this.currentLines = this.createRandomLines()
      } else if (mode === 'time') {
        this.currentLines = this.createTimeLines()
      }

      this.showResult()
    },

    createRandomLines() {
      let lines = []
      for (let i = 0; i < 6; i++) {
        lines.push(LINE_STATES[Math.floor(Math.random() * LINE_STATES.length)])
      }
      return lines
    },

    createTimeLines() {
      const now = new Date()
      const seed = now.getFullYear() + (now.getMonth() + 1) * 31 + now.getDate() * 12 + now.getHours() * 3600 + now.getMinutes() * 60 + now.getSeconds()
      let lines = []

      for (let i = 0; i < 6; i++) {
        let r = Math.sin(seed + i) * 10000
        r = r - Math.floor(r)
        lines.push(LINE_STATES[Math.floor(r * LINE_STATES.length)])
      }

      return lines
    },

    buildHexagramKeys(values) {
      let originalBinary = ''
      let changedBinary = ''
      let changeIndices = []

      for (let i = 0; i < values.length; i++) {
        let value = values[i]
        originalBinary += this.isYangLine(value) ? '1' : '0'
        changedBinary += this.isYangLine(this.getChangedLineValue(value)) ? '1' : '0'

        if (this.isChangingLine(value)) {
          changeIndices.push(i)
        }
      }

      return { originalBinary, changedBinary, changeIndices }
    },

    // 计算本卦、变卦和变爻位置，所有解卦规则都基于这三个结果。
    showResult() {
      let hexagramKeys = this.buildHexagramKeys(this.currentLines)
      let originalBinary = hexagramKeys.originalBinary
      let changedBinary = hexagramKeys.changedBinary
      let changeIndices = hexagramKeys.changeIndices
      let guaData = this.getHexagramData(originalBinary)
      this.resultGua = guaData
      this.resultLines = this.buildLineViews(this.currentLines)

      let changedGuaData = null
      if (changeIndices.length > 0) {
        this.showChange = true
        changedGuaData = this.getHexagramData(changedBinary)
        this.changedGua = changedGuaData
        this.changedLines = this.buildChangedLineViews(this.currentLines)
      } else {
        this.showChange = false
        this.changedLines = []
      }

      this.applyInterpretation(changeIndices, originalBinary, guaData, changedGuaData)
      this.vibrate('long')

      this.currentPage = 'result'
    },

    // 按传统变爻数量取辞，并控制结果页只展示本次真正要读的内容。
    applyInterpretation(changeIndices, originalBinary, benGua, bianGua) {
      let count = changeIndices.length
      let yaoNames = ['初爻', '二爻', '三爻', '四爻', '五爻', '上爻']
      this.showOriginalCi = false
      this.showChangedCi = false
      this.interpretationTexts = []

      if (count === 0) {
        this.interpretationRule = '无变爻，看本卦卦辞'
        this.showOriginalCi = true
      } else if (count === 1) {
        let idx = changeIndices[0]
        this.interpretationRule = '一爻变，看本卦变爻爻辞（' + yaoNames[idx] + '）'
        this.interpretationTexts = [{ label: yaoNames[idx], text: benGua.yaoCi[idx] }]
      } else if (count === 2) {
        let hi = changeIndices[changeIndices.length - 1]
        let lo = changeIndices[0]
        this.interpretationRule = '二爻变，看两个变爻爻辞，以上面爻（' + yaoNames[hi] + '）为主'
        this.interpretationTexts = [
          { label: yaoNames[hi] + '（主）', text: benGua.yaoCi[hi] },
          { label: yaoNames[lo] + '（辅）', text: benGua.yaoCi[lo] }
        ]
      } else if (count === 3) {
        this.interpretationRule = '三爻变，本卦卦辞为主，变卦卦辞为辅'
        this.showOriginalCi = true
        this.showChangedCi = true
      } else if (count === 4) {
        let unchanged = []
        for (let i = 0; i < 6; i++) {
          if (changeIndices.indexOf(i) === -1) unchanged.push(i)
        }
        let hi = unchanged[unchanged.length - 1]
        let lo = unchanged[0]
        this.interpretationRule = '四爻变，看变卦中两个不变爻爻辞，以下面爻（' + yaoNames[lo] + '）为主'
        if (bianGua) {
          this.interpretationTexts = [
            { label: yaoNames[lo] + '（主）', text: bianGua.yaoCi[lo] },
            { label: yaoNames[hi] + '（辅）', text: bianGua.yaoCi[hi] }
          ]
        }
      } else if (count === 5) {
        let unchanged = -1
        for (let i = 0; i < 6; i++) {
          if (changeIndices.indexOf(i) === -1) { unchanged = i; break }
        }
        this.interpretationRule = '五爻变，看变卦中唯一不变的爻辞（' + yaoNames[unchanged] + '）'
        if (bianGua) {
          this.interpretationTexts = [{ label: yaoNames[unchanged], text: bianGua.yaoCi[unchanged] }]
        }
      } else if (count === 6) {
        if (originalBinary === '111111') {
          this.interpretationRule = '六爻全变（乾卦），用九：见群龙无首，吉。'
          this.interpretationTexts = [{ label: '用九', text: '见群龙无首，吉。' }]
        } else if (originalBinary === '000000') {
          this.interpretationRule = '六爻全变（坤卦），用六：利永贞。'
          this.interpretationTexts = [{ label: '用六', text: '利永贞。' }]
        } else {
          this.interpretationRule = '六爻全变，看变卦卦辞'
          this.showChangedCi = true
        }
      }
    },

    // 回到首页时清掉本次起卦和解卦展示状态。
    resetApp() {
      this.currentPage = 'home'
      this.currentLines = []
      this.previewLines = []
      this.shakeCount = 0
      this.interpretationRule = ''
      this.interpretationTexts = []
      this.showOriginalCi = true
      this.showChangedCi = false
    }
  }
</script>
