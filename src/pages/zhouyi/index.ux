    font-weight: bold;
    color: #fbbf24;
  }

  .shake-result {
    width: 100%;
    text-align: center;
    font-size: 32px;
    color: #fbbf24;
    margin-top: 15px;
  }

  /* 起卦页与解卦页共用卦象样式 */
  .hexagram-container {
    flex-direction: column-reverse;
    align-items: center;
    justify-content: center;
    width: 100%;
    margin: 28px 0;
  }

  .yao-row {
    flex-direction: row;
