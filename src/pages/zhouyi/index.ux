  }

  .btn {
    width: 340px;
    height: 90px;
    background-color: #fbbf24;
    border-radius: 45px;
    text-align: center;
    line-height: 90px;
    font-size: 34px;
    font-weight: bold;
    color: #000000;
    margin-top: 24px;
  }

  .btn-outline {
    width: 340px;
    height: 90px;
    border-width: 2px;
    border-color: #4b5563;
    border-radius: 45px;
    text-align: center;
    line-height: 90px;
    font-size: 34px;
    color: #9ca3af;
    margin-top: 18px;
  }

  /* 起卦页铜钱显示 */
  .coin-area {
    flex-direction: column;
    align-items: center;
    margin-bottom: 28px;
  }

  .coin-row {
    flex-direction: row;
    gap: 38px;
  }

  .coin {
    width: 96px;
    height: 96px;
    border-radius: 48px;
    border-width: 5px;
    border-color: #fbbf24;
    text-align: center;
    line-height: 96px;
