<template>
  <div class="container">
    <!-- 首页：选择起卦方式 -->
    <div class="page" if="{{currentPage === 'home'}}">
      <text class="title">周易起卦</text>
      <text class="subtitle">心诚则灵 · 三不占</text>
      <div class="menu-list">
        <text class="menu-item" @click="goToRitual('shake')">手动摇卦</text>
        <text class="menu-item" @click="goToRitual('manual')">手工指定</text>
        <text class="menu-item" @click="startDivination('time')">时间起卦</text>
        <text class="menu-item" @click="startDivination('auto')">手环自动</text>
        <text class="menu-item" @click="showRules()">断卦规则</text>
      </div>
    </div>

    <!-- 三不占原则页面 -->
    <div class="page" if="{{currentPage === 'ritual'}}">
      <text class="title-small">三不占原则</text>
      <div class="card">
        <text class="rule-title">① 不诚不占</text>
        <text class="rule-text">此乃求教于神明，首重真诚。</text>
      </div>
      <div class="card">
        <text class="rule-title">② 不义不占</text>
        <text class="rule-text">不合乎正当性及合理性的问题，不必占问。</text>
      </div>
      <div class="card">
        <text class="rule-title">③ 不疑不占</text>
        <text class="rule-text">必须是理性难以测度之事。</text>
      </div>
      <text class="title-small mt">起卦须知</text>
      <text class="notice">集中意念，心中默念所测之事，一事一卦。</text>
      <text class="btn" @click="proceedToAction()">开始起卦</text>
      <text class="btn-outline" @click="goHome()">返回</text>
    </div>

    <!-- 断卦规则页面 -->
    <div class="page" if="{{currentPage === 'rules'}}" style="padding-top: 30px;">
      <text class="title-small">断卦规则</text>
      <text class="subtitle">根据变爻数量参照不同内容</text>

      <div class="card">
        <text class="rule-title">无变爻（0个）</text>
        <text class="rule-text">看本卦卦辞</text>
      </div>

      <div class="card">
        <text class="rule-title">一爻变</text>
        <text class="rule-text">看本卦变爻爻辞</text>
      </div>

      <div class="card">
        <text class="rule-title">二爻变</text>
        <text class="rule-text">看两个变爻爻辞，以上爻为主</text>
      </div>

      <div class="card">
        <text class="rule-title">三爻变</text>
        <text class="rule-text">看本卦卦辞为主，变卦卦辞为辅</text>
      </div>

      <div class="card">
        <text class="rule-title">四爻变</text>
        <text class="rule-text">看变卦两个不变爻爻辞，以下爻为主</text>
      </div>

      <div class="card">
        <text class="rule-title">五爻变</text>
        <text class="rule-text">看变卦中唯一不变的爻辞</text>
      </div>

      <div class="card">
        <text class="rule-title">六爻全变</text>
        <text class="rule-text">乾坤用九用六，其他看变卦卦辞</text>
      </div>

      <text class="btn-outline" @click="goHome()">返回</text>
    </div>

    <!-- 起卦页面 -->
    <div class="page" if="{{currentPage === 'action'}}">
      <text class="title-small">{{actionTitle}}</text>
      <text class="subtitle" if="{{currentMode === 'shake'}}">点击按钮抛掷铜钱</text>
      <text class="subtitle" if="{{currentMode === 'manual'}}">点击爻位切换阴阳</text>

      <!-- 铜钱动画区 -->
      <div class="coin-area" if="{{currentMode === 'shake'}}">
        <div class="coin-row">
          <text class="coin">{{coin1}}</text>
          <text class="coin">{{coin2}}</text>
          <text class="coin">{{coin3}}</text>
        </div>
      </div>
      <text class="shake-result" if="{{currentMode === 'shake'}}">{{shakeResult}}</text>

      <!-- 卦象预览 -->
      <div class="hexagram-container">
        <div class="yao-row" for="{{line in previewLines}}" @click="toggleLine(line.index)" if="{{currentMode === 'manual'}}">
          <div class="{{line.isOld ? 'yang-line old-line' : 'yang-line'}}" if="{{line.isYang}}"></div>
          <div class="yin-line" if="{{!line.isYang}}">
            <div class="{{line.isOld ? 'line old-line' : 'line'}}"></div>
            <div class="{{line.isOld ? 'line old-line' : 'line'}}"></div>
          </div>
        </div>
        <div class="yao-row" for="{{line in previewLines}}" elif="{{currentMode === 'shake'}}">
          <div class="{{line.isOld ? 'yang-line old-line' : 'yang-line'}}" if="{{line.isYang}}"></div>
          <div class="yin-line" if="{{!line.isYang}}">
            <div class="{{line.isOld ? 'line old-line' : 'line'}}"></div>
            <div class="{{line.isOld ? 'line old-line' : 'line'}}"></div>
          </div>
        </div>
      </div>

      <text class="btn" @click="shakeBtnClick()" if="{{currentMode === 'shake'}}">{{shakeText}}</text>
      <text class="btn" @click="showResult()" if="{{currentMode === 'manual'}}">确定</text>
      <text class="btn-outline" @click="goRitual()">返回</text>
    </div>

    <!-- 结果页面 -->
    <div class="page result-page" if="{{currentPage === 'result'}}">
      <scroll class="result-scroll" scroll-y="true">
        <text class="result-title">{{resultGua.name}}</text>
        <text class="result-subtitle">{{showChange ? '本卦' : '卦象'}}</text>

        <div class="hexagram-display">
          <div class="yao-row" for="{{line in resultLines}}">
            <div class="{{line.isOld ? 'yang-line old-line' : 'yang-line'}}" if="{{line.isYang}}"></div>
            <div class="yin-line" if="{{!line.isYang}}">
              <div class="{{line.isOld ? 'yin-line-left old-line' : 'yin-line-left'}}"></div>
              <div class="yin-line-space"></div>
              <div class="{{line.isOld ? 'yin-line-right old-line' : 'yin-line-right'}}"></div>
            </div>
          </div>
        </div>

        <div class="change-section" if="{{showChange}}">
          <text class="result-title" style="font-size: 48px;">{{changedGua.name}}</text>
          <text class="result-subtitle" style="margin-top: 10px; margin-bottom: 18px;">变卦</text>
          <div class="hexagram-display-small">
            <div class="yao-row-small" for="{{line in changedLines}}">
              <div class="yang-line-small" if="{{line.isYang}}"></div>
              <div class="yin-line-small" if="{{!line.isYang}}">
                <div class="yin-line-left-small"></div>
                <div class="yin-line-space-small"></div>
                <div class="yin-line-right-small"></div>
              </div>
            </div>
          </div>
        </div>

        <div class="card" if="{{interpretationRule}}">
          <div class="card-inline">
            <text class="card-label">取</text><text class="card-colon">:</text>
          </div>
          <text class="card-content">{{interpretationRule}}</text>
        </div>

        <div class="card" if="{{showChangedCi}}">
          <div class="card-inline">
            <text class="card-label">变</text><text class="card-colon">:</text>
          </div>
          <text class="card-content">{{changedGua.ci}}</text>
        </div>

        <div class="card" if="{{showOriginalCi}}">
          <div class="card-inline">
            <text class="card-label">本</text><text class="card-colon">:</text>
          </div>
          <text class="card-content">{{resultGua.ci}}</text>
        </div>

        <div class="card" for="{{item in interpretationTexts}}">
          <div class="card-inline">
            <text class="card-label">{{item.label}}</text><text class="card-colon">:</text>
          </div>
          <text class="yao-text">{{item.text}}</text>
        </div>

        <text class="btn" @click="resetApp()">重新起卦</text>
      </scroll>
    </div>
  </div>
</template>

<style>
  /* 页面基础布局 */
  .container {
    flex: 1;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: #000000;
    width: 100%;
    height: 100%;
    padding-left: 50px;
    padding-right: 50px;
  }

  .page {
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .result-page {
    justify-content: flex-start;
  }

  .result-scroll {
    width: 100%;
    height: 100%;
    flex-direction: column;
    align-items: center;
    padding-top: 40px;
    padding-bottom: 100px;
  }

  /* 标题、按钮和通用卡片 */
  .title {
    font-size: 72px;
    font-weight: bold;
    color: #fbbf24;
    margin-top: 35px;
  }

  .title-small {
    font-size: 54px;
    font-weight: bold;
    color: #fbbf24;
    margin-top: 28px;
    margin-bottom: 24px;
  }

  .subtitle {
    font-size: 30px;
    color: #9ca3af;
    margin-bottom: 28px;
  }

  .menu-list {
    width: 100%;
    flex-direction: column;
    align-items: center;
    margin-top: 35px;
  }

  .menu-item {
    width: 380px;
    height: 96px;
    background-color: #1f2937;
    border-radius: 24px;
    text-align: center;
